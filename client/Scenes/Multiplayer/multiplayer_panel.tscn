[gd_scene format=3]

[ext_resource type="Script" path="res://Scenes/Multiplayer/multiplayer_panel.gd" id="1_mp"]

[node name="MultiplayerPanel" type="PanelContainer"]
custom_minimum_size = Vector2(360, 360)
script = ExtResource("1_mp")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "MULTIPLAYER"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "OFFLINE"
horizontal_alignment = 1

[node name="ServerUrlInput" type="LineEdit" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "ws://173.212.207.80:8080/ws"
placeholder_text = "WebSocket signaling URL"

[node name="ConnectButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "CONNECT / RECONNECT"

[node name="StatusContainer" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="AdvSettingsButton" type="CheckBox" parent="VBoxContainer/StatusContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "Settings (WAN)"

[node name="Label" type="Label" parent="VBoxContainer/StatusContainer"]
layout_mode = 2
text = "TURN + Secret"

[node name="AdvancedContainer" type="VBoxContainer" parent="VBoxContainer"]
unique_name_in_owner = true
visible = false
layout_mode = 2
theme_override_constants/separation = 6

[node name="TurnUrlInput" type="LineEdit" parent="VBoxContainer/AdvancedContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "turn:173.212.207.80:3478"
placeholder_text = "TURN URL"

[node name="TurnUserInput" type="LineEdit" parent="VBoxContainer/AdvancedContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "nilbyte"
placeholder_text = "TURN username"

[node name="TurnPassInput" type="LineEdit" parent="VBoxContainer/AdvancedContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "secret123"
placeholder_text = "TURN password"
secret = true

[node name="SecretKeyInput" type="LineEdit" parent="VBoxContainer/AdvancedContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "secret123"
placeholder_text = "Signaling PSK"
secret = true

[node name="LobbyList" type="ItemList" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
auto_height = true
